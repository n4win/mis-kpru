model users {
    userId        Int          @id @default(autoincrement()) @map("user_id")
    username      String       @unique @db.VarChar(20)
    passwordHash  Bytes        @map("password_hash")
    passwordSalt  Bytes        @map("password_salt")
    firstName     String       @map("first_name") @db.VarChar(100)
    lastName      String       @map("last_name") @db.VarChar(100)
    roleId        Int          @map("role_id")
    role          roles        @relation(fields: [roleId], references: [roleId])
    depId         Int?         @map("dep_id")
    department    departments? @relation(fields: [depId], references: [depId])
    createDate    DateTime     @default(now()) @map("create_date")
    modifiedDate  DateTime     @updatedAt @map("modified_date")
    createdById   Int          @map("created_by_id")
    createdBy     users        @relation("CreatedBy", fields: [createdById], references: [userId], onUpdate: NoAction, onDelete: NoAction)
    modifiedById  Int          @map("modified_by_id")
    modifiedBy    users        @relation("ModifiedBy", fields: [modifiedById], references: [userId], onUpdate: NoAction, onDelete: NoAction)
    createdUsers  users[]      @relation("CreatedBy")
    modifiedUsers users[]      @relation("ModifiedBy")
}
